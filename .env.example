# Your shop name (https://admin.shopify.com/store/YOUR_SHOP_NAME)
NUXT_SHOPIFY_NAME="YOUR_SHOP_NAME"

# Storefront API
NUXT_SHOPIFY_CLIENTS_STOREFRONT_API_VERSION="2025-07"
NUXT_SHOPIFY_CLIENTS_STOREFRONT_PUBLIC_ACCESS_TOKEN="YOUR_PUBLIC_ACCESS_TOKEN"
NUXT_SHOPIFY_CLIENTS_STOREFRONT_PRIVATE_ACCESS_TOKEN="YOUR_PRIVATE_ACCESS_TOKEN"

# Admin API
NUXT_SHOPIFY_CLIENTS_ADMIN_API_VERSION="2025-07"
NUXT_SHOPIFY_CLIENTS_ADMIN_ACCESS_TOKEN="YOUR_ADMIN_ACCESS_TOKEN"

# Customer Account API
NUXT_SHOPIFY_CLIENTS_CUSTOMER_ACCOUNT_API_VERSION="2025-07"
NUXT_SHOPIFY_CLIENTS_CUSTOMER_ACCOUNT_SHOP_ID="YOUR_CUSTOMER_ACCOUNT_SHOP_ID"
NUXT_SHOPIFY_CLIENTS_CUSTOMER_ACCOUNT_CLIENT_ID="YOUR_CUSTOMER_ACCOUNT_CLIENT_ID"
NUXT_SHOPIFY_CLIENTS_CUSTOMER_ACCOUNT_CLIENT_SECRET="YOUR_CUSTOMER_ACCOUNT_CLIENT_SECRET"
